generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  phone        String?
  phoneVerifiedAt DateTime?
  expoPushToken String?
  expoPushTokenUpdatedAt DateTime?
  role         Role     @default(USER)

  addresses       UserAddress[]
  phoneVerifications PhoneVerificationSession[]
  orders          Order[]
  restaurants     Restaurant[]
  orderStatusLogs OrderStatusHistory[]
  generatedBillingCycles RestaurantBillingCycle[] @relation("BillingCycleGeneratedBy")
  billingPayments RestaurantPayment[] @relation("BillingPaymentCreatedBy")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model State {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique

  cities    City[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model City {
  id             String   @id @default(uuid())
  name           String
  stateId        String

  state          State    @relation(fields: [stateId], references: [id])
  neighborhoods  Neighborhood[]
  addresses      UserAddress[]
  restaurants    Restaurant[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([name, stateId])
  @@index([stateId])
}

model Neighborhood {
  id             String   @id @default(uuid())
  name           String
  cityId         String

  city           City     @relation(fields: [cityId], references: [id])
  addresses      UserAddress[]
  deliveryZones  RestaurantDeliveryZone[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([name, cityId])
  @@index([cityId])
}

model UserAddress {
  id              String   @id @default(uuid())
  userId          String
  label           String?
  street          String
  number          String
  complement      String?
  reference       String?
  zipCode         String?
  cityId          String
  neighborhoodId  String
  isDefault       Boolean  @default(false)

  user            User         @relation(fields: [userId], references: [id])
  city            City         @relation(fields: [cityId], references: [id])
  neighborhood    Neighborhood @relation(fields: [neighborhoodId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([cityId])
  @@index([neighborhoodId])
}

model Restaurant {
  id            String   @id @default(uuid())
  name          String
  description   String?
  logoUrl       String?
  bannerUrl     String?
  phone         String?
  address       String
  ownerId       String
  cityId        String?
  minOrder      Decimal? @db.Decimal(10, 2)
  isActive      Boolean  @default(true)

  owner         User     @relation(fields: [ownerId], references: [id])
  city          City?    @relation(fields: [cityId], references: [id])

  menuCategories MenuCategory[]
  menuItems      MenuItem[]
  orders         Order[]
  hours          OpeningHour[]
  deliveryZones  RestaurantDeliveryZone[]
  billingCycles  RestaurantBillingCycle[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ownerId])
  @@index([cityId])
  @@index([isActive])
}

model OpeningHour {
  id           String @id @default(uuid())
  restaurantId String
  dayOfWeek    Int
  openTime     String
  closeTime    String

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}

model RestaurantDeliveryZone {
  id             String   @id @default(uuid())
  restaurantId   String
  neighborhoodId String
  deliveryFee    Decimal  @db.Decimal(10, 2)
  minTime        Int
  maxTime        Int
  isActive       Boolean  @default(true)

  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id])
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([restaurantId, neighborhoodId])
  @@index([restaurantId])
  @@index([neighborhoodId])
  @@index([isActive])
}

model MenuCategory {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  description  String?
  imageUrl     String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  menuItems    MenuItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([sortOrder])
  @@index([isActive])
}

model MenuItem {
  id               String   @id @default(uuid())
  restaurantId     String
  categoryId       String?
  name             String
  description      String?
  price            Decimal  @db.Decimal(10, 2)
  imageUrl         String?
  isAvailable      Boolean  @default(true)
  sortOrder        Int      @default(0)
  isFeatured       Boolean  @default(false)
  promotionalText  String?
  allowsItemNotes  Boolean  @default(true)
  maxPerOrder      Int?

  restaurant       Restaurant    @relation(fields: [restaurantId], references: [id])
  category         MenuCategory? @relation(fields: [categoryId], references: [id])
  options          MenuItemOption[]
  orderItems       OrderItem[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([restaurantId])
  @@index([categoryId])
  @@index([isAvailable])
  @@index([sortOrder])
  @@index([isFeatured])
}

model MenuItemOption {
  id          String         @id @default(uuid())
  menuItemId  String
  name        String
  description String?
  optionType  OptionGroupType @default(ADDITION)
  required    Boolean        @default(false)
  minSelect   Int?
  maxSelect   Int?
  sortOrder   Int            @default(0)
  isActive    Boolean        @default(true)

  menuItem    MenuItem         @relation(fields: [menuItemId], references: [id])
  choices     MenuItemChoice[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([menuItemId])
  @@index([sortOrder])
  @@index([isActive])
}

model MenuItemChoice {
  id          String   @id @default(uuid())
  optionId     String
  name         String
  description  String?
  price        Decimal? @db.Decimal(10, 2)
  imageUrl     String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)

  option       MenuItemOption @relation(fields: [optionId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([optionId])
  @@index([sortOrder])
  @@index([isActive])
}


model RestaurantBillingCycle {
  id               String   @id @default(uuid())
  restaurantId     String
  periodStart      DateTime
  periodEnd        DateTime
  referenceYear    Int?
  referenceMonth   Int?
  grossSales       Decimal  @db.Decimal(10, 2)
  canceledSales    Decimal  @default(0) @db.Decimal(10, 2)
  commissionRate   Decimal  @db.Decimal(5, 4)
  commissionAmount Decimal  @db.Decimal(10, 2)
  netSales         Decimal  @db.Decimal(10, 2)
  totalOrders      Int      @default(0)
  billedOrders     Int      @default(0)
  canceledOrders   Int      @default(0)
  amountPaid       Decimal  @default(0) @db.Decimal(10, 2)
  amountDue        Decimal  @db.Decimal(10, 2)
  status           BillingCycleStatus @default(OPEN)
  dueDate          DateTime?
  notes            String?
  generatedByUserId String?

  restaurant       Restaurant @relation(fields: [restaurantId], references: [id])
  generatedByUser  User?      @relation("BillingCycleGeneratedBy", fields: [generatedByUserId], references: [id])
  items            RestaurantBillingItem[]
  payments         RestaurantPayment[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([restaurantId, periodStart, periodEnd])
  @@index([restaurantId])
  @@index([periodStart, periodEnd])
  @@index([status])
  @@index([generatedByUserId])
}

model RestaurantBillingItem {
  id               String   @id @default(uuid())
  billingCycleId   String
  orderId          String
  orderTotal       Decimal  @db.Decimal(10, 2)
  isCanceled       Boolean  @default(false)
  commissionBase   Decimal  @db.Decimal(10, 2)
  commissionRate   Decimal  @db.Decimal(5, 4)
  commissionAmount Decimal  @db.Decimal(10, 2)

  billingCycle     RestaurantBillingCycle @relation(fields: [billingCycleId], references: [id])
  order            Order                  @relation(fields: [orderId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([billingCycleId, orderId])
  @@index([billingCycleId])
  @@index([orderId])
  @@index([isCanceled])
}

model RestaurantPayment {
  id              String   @id @default(uuid())
  billingCycleId   String
  amount          Decimal  @db.Decimal(10, 2)
  paymentMethod   String?
  reference       String?
  note            String?
  paidAt          DateTime
  createdByUserId String?

  billingCycle    RestaurantBillingCycle @relation(fields: [billingCycleId], references: [id])
  createdByUser   User?                  @relation("BillingPaymentCreatedBy", fields: [createdByUserId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([billingCycleId])
  @@index([paidAt])
  @@index([createdByUserId])
}

model Order {
  id                   String        @id @default(uuid())
  userId               String
  restaurantId         String
  userAddressId        String?
  neighborhoodName     String?
  status               OrderStatus   @default(PENDING)
  paymentMethod        PaymentMethod
  subtotal             Decimal       @db.Decimal(10, 2)
  deliveryFee          Decimal       @db.Decimal(10, 2)
  total                Decimal       @db.Decimal(10, 2)
  notes                String?
  cashChangeFor        Decimal?      @db.Decimal(10, 2)

  deliveryName         String
  deliveryPhone        String
  deliveryStreet       String
  deliveryNumber       String
  deliveryDistrict     String
  deliveryCity         String
  deliveryState        String
  deliveryZipCode      String
  deliveryComplement   String?
  deliveryReference    String?

  acceptedAt           DateTime?
  preparingAt          DateTime?
  deliveryAt           DateTime?
  deliveredAt          DateTime?
  canceledAt           DateTime?

  user                 User          @relation(fields: [userId], references: [id])
  restaurant           Restaurant    @relation(fields: [restaurantId], references: [id])
  items                OrderItem[]
  statusHistory        OrderStatusHistory[]
  billingItems         RestaurantBillingItem[]

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([userId])
  @@index([restaurantId])
  @@index([status])
  @@index([createdAt])
  @@index([userAddressId])
}

model OrderItem {
  id                  String   @id @default(uuid())
  orderId             String
  menuItemId          String
  name                String
  description         String?
  imageUrl            String?
  quantity            Int
  baseUnitPrice       Decimal  @db.Decimal(10, 2)
  unitPrice           Decimal  @db.Decimal(10, 2)
  totalPrice          Decimal  @db.Decimal(10, 2)
  notes               String?

  order               Order    @relation(fields: [orderId], references: [id])
  menuItem            MenuItem @relation(fields: [menuItemId], references: [id])
  selections          OrderItemSelection[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([orderId])
  @@index([menuItemId])
}

model OrderItemSelection {
  id          String   @id @default(uuid())
  orderItemId String
  optionId    String?
  optionName  String
  choiceId    String?
  choiceName  String
  price       Decimal? @db.Decimal(10, 2)

  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderItemId])
}

model OrderStatusHistory {
  id               String      @id @default(uuid())
  orderId          String
  fromStatus       OrderStatus?
  toStatus         OrderStatus
  changedByUserId  String?
  note             String?

  order            Order       @relation(fields: [orderId], references: [id])
  changedByUser    User?       @relation(fields: [changedByUserId], references: [id])

  createdAt        DateTime    @default(now())

  @@index([orderId])
  @@index([changedByUserId])
  @@index([createdAt])
}


model PhoneVerificationSession {
  id           String   @id @default(uuid())
  userId       String
  phone        String
  channel      VerificationChannel @default(SMS)
  provider     VerificationProvider @default(APIBRASIL)
  providerKey  String?
  localCodeHash String?
  status       VerificationStatus @default(PENDING)
  attempts     Int      @default(0)
  resendCount  Int      @default(1)
  nextAllowedAt DateTime?
  expiresAt    DateTime?
  verifiedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([phone])
  @@index([status])
}

enum VerificationChannel {
  SMS
  WHATSAPP
}

enum VerificationProvider {
  APIBRASIL
  INTERNAL
}

enum VerificationStatus {
  PENDING
  VERIFIED
  EXPIRED
  FAILED
}
enum Role {
  USER
  RESTAURANT
  ADMIN
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  DELIVERY
  DELIVERED
  CANCELED
}

enum BillingCycleStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum OptionGroupType {
  SIZE
  FRUIT
  TOPPING
  COMPLEMENT
  SYRUP
  ADDITION
  CUSTOMIZATION
}
