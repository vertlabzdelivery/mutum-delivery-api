generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  referralCode String   @unique
  phone        String?
  phoneVerifiedAt DateTime?
  expoPushToken String?
  expoPushTokenUpdatedAt DateTime?
  role         Role     @default(USER)
  isActive     Boolean  @default(true)
  deletedAt    DateTime?

  addresses       UserAddress[]
  phoneVerifications PhoneVerificationSession[]
  passwordResets  PasswordResetSession[]
  orders          Order[]
  restaurants     Restaurant[]
  orderStatusLogs OrderStatusHistory[]
  generatedBillingCycles RestaurantBillingCycle[] @relation("BillingCycleGeneratedBy")
  billingPayments RestaurantPayment[] @relation("BillingPaymentCreatedBy")
  createdPromotionalCoupons PromotionalCoupon[] @relation("PromotionalCouponCreatedByAdmin")
  promotionalCouponUsages PromotionalCouponUsage[]
  referralUsagesAsOwner ReferralUsage[] @relation("ReferralUsageOwner")
  referralUsagesAsReferred ReferralUsage[] @relation("ReferralUsageReferred")
  referralRewards ReferralReward[] @relation("ReferralRewardOwner")
  ordersWithReferralOwner Order[] @relation("OrderReferralOwner")
  adminDisabledRestaurants Restaurant[] @relation("RestaurantAdminDisabledBy")
  restaurantFavorites RestaurantFavorite[]
  restaurantReviews RestaurantReview[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([isActive])
  @@index([deletedAt])
}

model State {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique

  cities    City[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model City {
  id             String   @id @default(uuid())
  name           String
  stateId        String

  state          State    @relation(fields: [stateId], references: [id])
  neighborhoods  Neighborhood[]
  addresses      UserAddress[]
  restaurants    Restaurant[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([name, stateId])
  @@index([stateId])
}

model Neighborhood {
  id             String   @id @default(uuid())
  name           String
  cityId         String

  city           City     @relation(fields: [cityId], references: [id])
  addresses      UserAddress[]
  deliveryZones  RestaurantDeliveryZone[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([name, cityId])
  @@index([cityId])
}

model UserAddress {
  id              String   @id @default(uuid())
  userId          String
  label           String?
  street          String
  number          String
  complement      String?
  reference       String?
  zipCode         String?
  cityId          String
  neighborhoodId  String
  isDefault       Boolean  @default(false)

  user            User         @relation(fields: [userId], references: [id])
  city            City         @relation(fields: [cityId], references: [id])
  neighborhood    Neighborhood @relation(fields: [neighborhoodId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([cityId])
  @@index([neighborhoodId])
}

model Restaurant {
  id            String   @id @default(uuid())
  name          String
  description   String?
  logoUrl       String?
  bannerUrl     String?
  phone         String?
  address       String
  ownerId       String
  cityId        String?
  minOrder      Decimal? @db.Decimal(10, 2)
  isActive      Boolean  @default(true)
  acceptsReferralCoupons    Boolean  @default(true)
  acceptsPromotionalCoupons Boolean  @default(true)
  adminDisabledAt DateTime?
  adminDisabledByUserId String?
  favoritesCount Int @default(0)
  ratingCount Int @default(0)
  averageRating Decimal @default(0) @db.Decimal(3, 2)

  owner         User     @relation(fields: [ownerId], references: [id])
  city          City?    @relation(fields: [cityId], references: [id])
  adminDisabledByUser User? @relation("RestaurantAdminDisabledBy", fields: [adminDisabledByUserId], references: [id])

  favorites      RestaurantFavorite[]
  reviews        RestaurantReview[]
  menuCategories  MenuCategory[]
  menuItems       MenuItem[]
  orders          Order[]
  hours           OpeningHour[]
  deliveryZones   RestaurantDeliveryZone[]
  billingCycles   RestaurantBillingCycle[]
  storeCategories RestaurantStoreCategory[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([ownerId])
  @@index([cityId])
  @@index([isActive])
  @@index([adminDisabledAt])
  @@index([adminDisabledByUserId])
}

model RestaurantFavorite {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String
  createdAt    DateTime @default(now())

  user         User      @relation(fields: [userId], references: [id])
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([userId, restaurantId])
  @@index([userId])
  @@index([restaurantId])
  @@index([createdAt])
}

model RestaurantReview {
  id           String   @id @default(uuid())
  userId       String
  restaurantId String
  rating       Int
  comment      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User      @relation(fields: [userId], references: [id])
  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@unique([userId, restaurantId])
  @@index([userId])
  @@index([restaurantId])
  @@index([rating])
  @@index([createdAt])
}

model StoreCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  iconUrl   String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)

  restaurants RestaurantStoreCategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}

model RestaurantStoreCategory {
  restaurantId    String
  storeCategoryId String

  restaurant    Restaurant    @relation(fields: [restaurantId], references: [id])
  storeCategory StoreCategory @relation(fields: [storeCategoryId], references: [id])

  assignedAt DateTime @default(now())

  @@id([restaurantId, storeCategoryId])
  @@index([restaurantId])
  @@index([storeCategoryId])
}

model OpeningHour {
  id           String @id @default(uuid())
  restaurantId String
  dayOfWeek    Int
  openTime     String
  closeTime    String

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])

  @@index([restaurantId])
}

model RestaurantDeliveryZone {
  id             String   @id @default(uuid())
  restaurantId   String
  neighborhoodId String
  deliveryFee    Decimal  @db.Decimal(10, 2)
  minTime        Int
  maxTime        Int
  isActive       Boolean  @default(true)

  restaurant     Restaurant   @relation(fields: [restaurantId], references: [id])
  neighborhood   Neighborhood @relation(fields: [neighborhoodId], references: [id])

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([restaurantId, neighborhoodId])
  @@index([restaurantId])
  @@index([neighborhoodId])
  @@index([isActive])
}

model MenuCategory {
  id           String   @id @default(uuid())
  restaurantId String
  name         String
  description  String?
  imageUrl     String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)

  restaurant   Restaurant @relation(fields: [restaurantId], references: [id])
  menuItems    MenuItem[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([restaurantId, name])
  @@index([restaurantId])
  @@index([sortOrder])
  @@index([isActive])
}

model MenuItem {
  id               String   @id @default(uuid())
  restaurantId     String
  categoryId       String?
  name             String
  description      String?
  price            Decimal  @db.Decimal(10, 2)
  imageUrl         String?
  isAvailable      Boolean  @default(true)
  sortOrder        Int      @default(0)
  isFeatured       Boolean  @default(false)
  promotionalText  String?
  allowsItemNotes  Boolean  @default(true)
  maxPerOrder      Int?

  restaurant       Restaurant    @relation(fields: [restaurantId], references: [id])
  category         MenuCategory? @relation(fields: [categoryId], references: [id])
  options          MenuItemOption[]
  orderItems       OrderItem[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([restaurantId])
  @@index([categoryId])
  @@index([isAvailable])
  @@index([sortOrder])
  @@index([isFeatured])
}

model MenuItemOption {
  id          String         @id @default(uuid())
  menuItemId  String
  name        String
  description String?
  optionType  OptionGroupType @default(ADDITION)
  required    Boolean        @default(false)
  minSelect   Int?
  maxSelect   Int?
  sortOrder   Int            @default(0)
  isActive    Boolean        @default(true)

  menuItem    MenuItem         @relation(fields: [menuItemId], references: [id])
  choices     MenuItemChoice[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([menuItemId])
  @@index([sortOrder])
  @@index([isActive])
}

model MenuItemChoice {
  id          String   @id @default(uuid())
  optionId     String
  name         String
  description  String?
  price        Decimal? @db.Decimal(10, 2)
  imageUrl     String?
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  isDefault    Boolean  @default(false)

  option       MenuItemOption @relation(fields: [optionId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([optionId])
  @@index([sortOrder])
  @@index([isActive])
}


model RestaurantBillingCycle {
  id               String   @id @default(uuid())
  restaurantId     String
  periodStart      DateTime
  periodEnd        DateTime
  referenceYear    Int?
  referenceMonth   Int?
  grossSales       Decimal  @db.Decimal(10, 2)
  canceledSales    Decimal  @default(0) @db.Decimal(10, 2)
  commissionRate   Decimal  @db.Decimal(5, 4)
  commissionAmount Decimal  @db.Decimal(10, 2)
  netSales         Decimal  @db.Decimal(10, 2)
  totalOrders      Int      @default(0)
  billedOrders     Int      @default(0)
  canceledOrders   Int      @default(0)
  amountPaid       Decimal  @default(0) @db.Decimal(10, 2)
  amountDue        Decimal  @db.Decimal(10, 2)
  status           BillingCycleStatus @default(OPEN)
  dueDate          DateTime?
  notes            String?
  generatedByUserId String?

  restaurant       Restaurant @relation(fields: [restaurantId], references: [id])
  generatedByUser  User?      @relation("BillingCycleGeneratedBy", fields: [generatedByUserId], references: [id])
  items            RestaurantBillingItem[]
  payments         RestaurantPayment[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([restaurantId, periodStart, periodEnd])
  @@index([restaurantId])
  @@index([periodStart, periodEnd])
  @@index([status])
  @@index([generatedByUserId])
}

model RestaurantBillingItem {
  id               String   @id @default(uuid())
  billingCycleId   String
  orderId          String
  orderTotal       Decimal  @db.Decimal(10, 2)
  isCanceled       Boolean  @default(false)
  commissionBase   Decimal  @db.Decimal(10, 2)
  commissionRate   Decimal  @db.Decimal(5, 4)
  commissionAmount Decimal  @db.Decimal(10, 2)

  billingCycle     RestaurantBillingCycle @relation(fields: [billingCycleId], references: [id])
  order            Order                  @relation(fields: [orderId], references: [id])

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([billingCycleId, orderId])
  @@index([billingCycleId])
  @@index([orderId])
  @@index([isCanceled])
}

model RestaurantPayment {
  id              String   @id @default(uuid())
  billingCycleId   String
  amount          Decimal  @db.Decimal(10, 2)
  paymentMethod   String?
  reference       String?
  note            String?
  paidAt          DateTime
  createdByUserId String?

  billingCycle    RestaurantBillingCycle @relation(fields: [billingCycleId], references: [id])
  createdByUser   User?                  @relation("BillingPaymentCreatedBy", fields: [createdByUserId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([billingCycleId])
  @@index([paidAt])
  @@index([createdByUserId])
}

model Order {
  id                   String        @id @default(uuid())
  userId               String
  restaurantId         String
  userAddressId        String?
  neighborhoodName     String?
  status               OrderStatus   @default(PENDING)
  paymentMethod        PaymentMethod
  subtotal             Decimal       @db.Decimal(10, 2)
  deliveryFee          Decimal       @db.Decimal(10, 2)
  total                Decimal       @db.Decimal(10, 2)
  notes                String?
  cashChangeFor        Decimal?      @db.Decimal(10, 2)
  couponCode           String?
  couponType           CouponType?
  discountAmount       Decimal       @default(0) @db.Decimal(10, 2)
  promotionalCouponId  String?
  referralOwnerUserId  String?
  referralRewardId     String?       @unique

  deliveryName         String
  deliveryPhone        String
  deliveryStreet       String
  deliveryNumber       String
  deliveryDistrict     String
  deliveryCity         String
  deliveryState        String
  deliveryZipCode      String
  deliveryComplement   String?
  deliveryReference    String?

  acceptedAt           DateTime?
  preparingAt          DateTime?
  deliveryAt           DateTime?
  deliveredAt          DateTime?
  canceledAt           DateTime?

  user                 User          @relation(fields: [userId], references: [id])
  restaurant           Restaurant    @relation(fields: [restaurantId], references: [id])
  promotionalCoupon    PromotionalCoupon? @relation(fields: [promotionalCouponId], references: [id])
  referralOwnerUser    User?         @relation("OrderReferralOwner", fields: [referralOwnerUserId], references: [id])
  referralReward       ReferralReward? @relation("OrderUsesReferralReward", fields: [referralRewardId], references: [id])
  items                OrderItem[]
  statusHistory        OrderStatusHistory[]
  billingItems         RestaurantBillingItem[]
  promotionalCouponUsage PromotionalCouponUsage?
  referralUsage        ReferralUsage?

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt

  @@index([userId])
  @@index([restaurantId])
  @@index([status])
  @@index([createdAt])
  @@index([userAddressId])
  @@index([promotionalCouponId])
  @@index([referralOwnerUserId])
  @@index([couponCode])
}

model PromotionalCoupon {
  id                String   @id @default(uuid())
  code              String   @unique
  discountType      DiscountType @default(PERCENT)
  discountValue     Decimal  @db.Decimal(10, 2)
  maxDiscountAmount Decimal? @db.Decimal(10, 2)
  minOrderAmount    Decimal  @default(0) @db.Decimal(10, 2)
  maxUses           Int
  usedCount         Int      @default(0)
  isActive          Boolean  @default(true)
  startsAt          DateTime?
  endsAt            DateTime?
  createdByAdminId  String?

  createdByAdmin User? @relation("PromotionalCouponCreatedByAdmin", fields: [createdByAdminId], references: [id])
  usages         PromotionalCouponUsage[]
  orders         Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([code])
  @@index([startsAt, endsAt])
  @@index([createdByAdminId])
}

model PromotionalCouponUsage {
  id                 String   @id @default(uuid())
  promotionalCouponId String
  orderId            String   @unique
  userId             String
  couponCode         String
  discountAmount     Decimal  @db.Decimal(10, 2)
  usedAt             DateTime @default(now())

  promotionalCoupon PromotionalCoupon @relation(fields: [promotionalCouponId], references: [id])
  order             Order             @relation(fields: [orderId], references: [id])
  user              User              @relation(fields: [userId], references: [id])

  @@index([promotionalCouponId])
  @@index([userId])
  @@index([usedAt])
}

model ReferralUsage {
  id                 String   @id @default(uuid())
  referralOwnerUserId String
  referredUserId     String
  orderId            String   @unique
  referralCode       String
  status             ReferralUsageStatus @default(PENDING_CONFIRMATION)
  discountType       DiscountType
  discountValue      Decimal  @db.Decimal(10, 2)
  maxDiscountAmount  Decimal? @db.Decimal(10, 2)
  discountAmount     Decimal  @db.Decimal(10, 2)
  rewardGrantedAt    DateTime?
  usedAt             DateTime @default(now())

  referralOwnerUser User @relation("ReferralUsageOwner", fields: [referralOwnerUserId], references: [id])
  referredUser     User @relation("ReferralUsageReferred", fields: [referredUserId], references: [id])
  order            Order @relation(fields: [orderId], references: [id])
  reward           ReferralReward?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([referredUserId])
  @@index([referralOwnerUserId])
  @@index([referredUserId])
  @@index([status])
  @@index([referralCode])
}

model ReferralReward {
  id                 String   @id @default(uuid())
  code               String   @unique
  referralOwnerUserId String
  referralUsageId    String   @unique
  discountType       DiscountType
  discountValue      Decimal  @db.Decimal(10, 2)
  maxDiscountAmount  Decimal? @db.Decimal(10, 2)
  status             ReferralRewardStatus @default(PENDING)
  grantedAt          DateTime?
  usedAt             DateTime?
  usedOrderId        String?  @unique
  appliedDiscountAmount Decimal? @db.Decimal(10, 2)

  referralOwnerUser User @relation("ReferralRewardOwner", fields: [referralOwnerUserId], references: [id])
  referralUsage     ReferralUsage @relation(fields: [referralUsageId], references: [id])
  usedOrder         Order? @relation("OrderUsesReferralReward")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([referralOwnerUserId])
  @@index([status])
}

model OrderItem {
  id                  String   @id @default(uuid())
  orderId             String
  menuItemId          String
  name                String
  description         String?
  imageUrl            String?
  quantity            Int
  baseUnitPrice       Decimal  @db.Decimal(10, 2)
  unitPrice           Decimal  @db.Decimal(10, 2)
  totalPrice          Decimal  @db.Decimal(10, 2)
  notes               String?

  order               Order    @relation(fields: [orderId], references: [id])
  menuItem            MenuItem @relation(fields: [menuItemId], references: [id])
  selections          OrderItemSelection[]

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([orderId])
  @@index([menuItemId])
}

model OrderItemSelection {
  id          String   @id @default(uuid())
  orderItemId String
  optionId    String?
  optionName  String
  choiceId    String?
  choiceName  String
  price       Decimal? @db.Decimal(10, 2)

  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([orderItemId])
}

model OrderStatusHistory {
  id               String      @id @default(uuid())
  orderId          String
  fromStatus       OrderStatus?
  toStatus         OrderStatus
  changedByUserId  String?
  note             String?

  order            Order       @relation(fields: [orderId], references: [id])
  changedByUser    User?       @relation(fields: [changedByUserId], references: [id])

  createdAt        DateTime    @default(now())

  @@index([orderId])
  @@index([changedByUserId])
  @@index([createdAt])
}


model PhoneVerificationSession {
  id           String   @id @default(uuid())
  userId       String
  phone        String
  channel      VerificationChannel @default(SMS)
  provider     VerificationProvider @default(APIBRASIL)
  providerKey  String?
  localCodeHash String?
  status       VerificationStatus @default(PENDING)
  attempts     Int      @default(0)
  resendCount  Int      @default(1)
  nextAllowedAt DateTime?
  expiresAt    DateTime?
  verifiedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user         User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([phone])
  @@index([status])
}


model PasswordResetSession {
  id                  String   @id @default(uuid())
  userId              String
  phone               String
  channel             VerificationChannel @default(SMS)
  provider            VerificationProvider @default(INTERNAL)
  providerKey         String?
  localCodeHash       String?
  resetTokenHash      String?  @unique
  status              PasswordResetStatus @default(PENDING)
  attempts            Int      @default(0)
  resendCount         Int      @default(1)
  nextAllowedAt       DateTime?
  expiresAt           DateTime?
  verifiedAt          DateTime?
  resetTokenExpiresAt DateTime?
  consumedAt          DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user                User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([phone])
  @@index([status])
}

enum VerificationChannel {
  SMS
  WHATSAPP
}

enum VerificationProvider {
  APIBRASIL
  INTERNAL
}

enum VerificationStatus {
  PENDING
  VERIFIED
  EXPIRED
  FAILED
}

enum PasswordResetStatus {
  PENDING
  VERIFIED
  USED
  EXPIRED
  FAILED
}

enum Role {
  USER
  RESTAURANT
  ADMIN
}

enum OrderStatus {
  PENDING
  ACCEPTED
  PREPARING
  DELIVERY
  DELIVERED
  CANCELED
}

enum BillingCycleStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
}

enum PaymentMethod {
  CASH
  PIX
  CREDIT_CARD
  DEBIT_CARD
}

enum OptionGroupType {
  SIZE
  FRUIT
  TOPPING
  COMPLEMENT
  SYRUP
  ADDITION
  CUSTOMIZATION
}

enum CouponType {
  REFERRAL
  PROMOTIONAL
  REFERRAL_REWARD
}

enum DiscountType {
  PERCENT
  FIXED
}

enum ReferralUsageStatus {
  PENDING_CONFIRMATION
  CONFIRMED
}

enum ReferralRewardStatus {
  PENDING
  AVAILABLE
  USED
}
