DATABASE_URL="postgresql://usuario:senha@localhost:5432/uai_pede"
JWT_SECRET="troque-esta-chave"
JWT_REFRESH_SECRET="troque-esta-chave-refresh"
JWT_ACCESS_TOKEN_TTL="15m"
JWT_REFRESH_TOKEN_TTL="7d"
PORT=3001
APP_BRAND_NAME="UaiPede"

# CORS — separe múltiplas origens por vírgula
# Ex: CORS_ORIGIN=https://meuapp.com,https://painel.meuapp.com
CORS_ORIGIN=

# Auth security / rate limit
AUTH_LOGIN_RATE_LIMIT_PER_IP=20
AUTH_LOGIN_RATE_LIMIT_PER_EMAIL=10
AUTH_LOGIN_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_LOGIN_FAILURE_BLOCK_THRESHOLD=5
AUTH_LOGIN_FAILURE_WINDOW_SECONDS=900
AUTH_LOGIN_BLOCK_SECONDS=900
AUTH_SMS_RATE_LIMIT_PER_IP=8
AUTH_SMS_RATE_LIMIT_PER_TARGET=3
AUTH_SMS_RATE_LIMIT_WINDOW_SECONDS=900
AUTH_PASSWORD_RECOVERY_RATE_LIMIT_PER_IP=6
AUTH_PASSWORD_RECOVERY_RATE_LIMIT_PER_PHONE=3
AUTH_PASSWORD_RECOVERY_RATE_LIMIT_WINDOW_SECONDS=1800
AUTH_VERIFICATION_BLOCK_SECONDS=900

# Observability
API_SLOW_REQUEST_THRESHOLD_MS=800
DB_SLOW_QUERY_THRESHOLD_MS=400

# Cache Redis
# IMPORTANTE: Em ambientes Vercel Serverless, o Redis é OBRIGATÓRIO para que
# o rate-limiting funcione corretamente entre múltiplas instâncias da função.
# Sem Redis, cada instância tem seu próprio contador em memória (não compartilhado).
CACHE_ENABLED=true
REDIS_URL="redis://default:SUA_SENHA@SEU_HOST:PORTA"
CACHE_TTL_RESTAURANTS=60
CACHE_TTL_RESTAURANT_DETAIL=90
CACHE_TTL_MENU=60
CACHE_TTL_MENU_ITEM=120
CACHE_TTL_DELIVERY_ZONES=300
CACHE_TTL_LOCATIONS=86400
REDIS_TLS=false
REDIS_CONNECT_TIMEOUT_MS=1500
REDIS_OPERATION_TIMEOUT_MS=500
REDIS_BACKOFF_MS=15000

# Upload de imagens com Vercel Blob
BLOB_READ_WRITE_TOKEN="cole_aqui_o_token_do_blob_para_rodar_localmente"
BLOB_MAX_RESTAURANT_BANNER_BYTES=1572864
BLOB_MAX_RESTAURANT_LOGO_BYTES=716800
BLOB_MAX_MENU_ITEM_IMAGE_BYTES=921600
BLOB_MAX_STORE_CATEGORY_ICON_BYTES=307200

# Verificação por SMS via APIBrasil
APIBRASIL_BEARER_TOKEN="seu_bearer_token"
VERIFICATION_DEFAULT_CHANNEL="SMS"
APIBRASIL_SMS_TYPE="sms-otp"
APIBRASIL_SMS_OPERATOR="claro"

# Push do Expo
EXPO_PUSH_ENABLED=true

# Recuperação de senha por SMS
PASSWORD_RESET_TOKEN_TTL_MINUTES=15

# Ably realtime para painel do restaurante
ABLY_API_KEY=
# TTL do token Ably em segundos. Padrão: 82800 (23h).
# O frontend deve usar o campo `expiresAt` da resposta para saber quando renovar.
# NAO fazer polling desta rota em intervalos fixos — use o expiresAt.
ABLY_TOKEN_TTL_SECONDS=82800
ABLY_CHANNEL_PREFIX=restaurants

# ─── Vercel Speed Insights ─────────────────────────────────────────────────────
# Speed Insights é ativado pelo painel do Vercel:
#   Project Settings → Speed Insights → Enable
#
# Este interceptor emite automaticamente os headers:
#   • Server-Timing: handler;dur=<ms>;desc="<rota>"   ← lido pelo Vercel e DevTools
#   • X-Response-Time: <ms>                           ← para debug e testes
#
# Não é necessária nenhuma variável de ambiente adicional para o interceptor.
# O Vercel coleta durações de Function executions automaticamente no dashboard.

# ─── Log centralizado (opcional, mas recomendado) ──────────────────────────────
# Betterstack: https://logs.betterstack.com → New Source → HTTP
BETTERSTACK_LOG_TOKEN=
BETTERSTACK_LOG_URL=https://in.logs.betterstack.com
LOG_SERVICE_NAME=uai-pede-api

# Sistema de indicação e recompensas
REFERRAL_COUPON_ENABLED=true
REFERRAL_DISCOUNT_TYPE=PERCENT
REFERRAL_DISCOUNT_VALUE=15
REFERRAL_MAX_DISCOUNT=999999
REFERRAL_ONLY_FIRST_ORDER=true
REFERRAL_REWARD_ENABLED=true
REFERRAL_REWARD_TYPE=PERCENT
REFERRAL_REWARD_VALUE=15
REFERRAL_REWARD_MAX_DISCOUNT=999999
