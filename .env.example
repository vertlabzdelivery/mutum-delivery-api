DATABASE_URL="postgresql://usuario:senha@localhost:5432/uai_pede"
JWT_SECRET="troque-esta-chave"
JWT_REFRESH_SECRET="troque-esta-chave-refresh"
PORT=3001
APP_BRAND_NAME="UaiPede"

# Cache Redis
CACHE_ENABLED=true
REDIS_URL="redis://default:SUA_SENHA@SEU_HOST:PORTA"
CACHE_TTL_RESTAURANTS=60
CACHE_TTL_RESTAURANT_DETAIL=90
CACHE_TTL_MENU=60
CACHE_TTL_MENU_ITEM=120
CACHE_TTL_DELIVERY_ZONES=300
CACHE_TTL_LOCATIONS=86400
REDIS_TLS=false
REDIS_CONNECT_TIMEOUT_MS=1500
REDIS_OPERATION_TIMEOUT_MS=500
REDIS_BACKOFF_MS=15000

# Upload de imagens com Vercel Blob
BLOB_READ_WRITE_TOKEN="cole_aqui_o_token_do_blob_para_rodar_localmente"
BLOB_MAX_RESTAURANT_LOGO_BYTES=716800
BLOB_MAX_MENU_ITEM_IMAGE_BYTES=921600

# Verificação por SMS via APIBrasil
APIBRASIL_BEARER_TOKEN="seu_bearer_token"
VERIFICATION_DEFAULT_CHANNEL="SMS"

# Push do Expo
EXPO_PUSH_ENABLED=true

APIBRASIL_SMS_TYPE="sms-otp"
APIBRASIL_SMS_OPERATOR="claro"

# Recuperação de senha por SMS
PASSWORD_RESET_TOKEN_TTL_MINUTES=15
